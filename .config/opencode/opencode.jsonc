{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-sonnet-4.6",
  "small_model": "github-copilot/claude-haiku-4.5",
  "default_agent": "build",
  "permission": {
    "external_directory": {
      "~/code/**": "allow",
      "~/go/pkg/mod/**": "allow",
    },
    "edit": {
      "~/go/pkg/mod/**": "deny",
    },
    "webfetch": "allow",
    "websearch": "ask",
  },
  "mcp": {
    "context7": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "gh_grep": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.grep.app"
    }
  },
  "plugin": [
    "opencode-scheduler",
  ]
}
