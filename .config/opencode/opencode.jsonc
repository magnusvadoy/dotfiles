{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/gpt-5.2-codex",
  "small_model": "github-copilot/claude-haiku-4.5",
  "default_agent": "build",
  "permission": {
    "external_directory": {
      "~/code/**": "allow",
    },
    "webfetch": "allow",
    "websearch": "allow",
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    }
  }
}
